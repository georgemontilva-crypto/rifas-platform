NODE_ENV=development
PORT=3001

# MySQL en Railway: usa la URL de conexión pública o interna del servicio
DATABASE_URL="mysql://usuario:password@host:puerto/railway"

# Genera estos secretos con: openssl rand -hex 32 (mínimo 32 caracteres, NUNCA los reutilices entre entornos)
JWT_SECRET=
JWT_REFRESH_SECRET=

FRONTEND_URL=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Resend (emails transaccionales)
RESEND_API_KEY=

# Cloudflare R2 (almacenamiento de imágenes / comprobantes de pago)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rifas-uploads
R2_PUBLIC_URL=
